---
// 6. Pricing — Premium & Pro
import { REGISTER_URL } from '../urls';

const checkIcon = (color: string) => `
  <svg viewBox="0 0 24 24" fill="none" stroke="${color}" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
    <polyline points="20 6 9 17 4 12"/>
  </svg>
`;

// Le paramètre ?checkout=... déclenche le checkout Stripe du plan choisi
// juste après l'inscription sur l'app.
const plans = [
  {
    name: 'Premium',
    price: '10€',
    period: 'HT/mois',
    tag: "L'essentiel pour votre carte en ligne.",
    features: [
      'QR code dédié',
      'Menu numérique illimité',
      'Personnalisation (couleurs, logo)',
      'Mises à jour en temps réel',
    ],
    href: `${REGISTER_URL}?checkout=premium`,
    featured: false,
  },
  {
    name: 'Pro',
    tag: 'La commande à table en plus.',
    features: [
      'Tout le plan Premium',
      'Commande à table',
      'Suivi des commandes en temps réel',
      'Gestion des tables & statistiques',
    ],
    featured: true,
    // Plan pas encore commercialisé : on masque le prix et on désactive
    // l'inscription tant que la commande à table est en développement.
    comingSoon: true,
  },
];
---

<section class="pricing section-pad" id="pricing">
  <div class="container">
    <div class="section-head center reveal">
      <span class="eyebrow">Tarifs</span>
      <h2 class="section-title">Simple, transparent, <i>sans surprise.</i></h2>
      <p class="section-sub">Deux formules, sans engagement. Changez ou résiliez quand vous voulez.</p>
    </div>

    <div class="price-grid">
      {plans.map((p) => (
        <div class={`price-card reveal${p.featured ? ' pro' : ''}`}>
          {p.comingSoon
            ? <div class="recommended-badge">Bientôt disponible</div>
            : p.featured && <div class="recommended-badge">Recommandé</div>}
          <div class="plan">{p.name}</div>
          {p.comingSoon
            ? <div class="amount coming-soon-price">Bientôt</div>
            : <div class="amount">{p.price}<span> {p.period}</span></div>}
          <div class="tag">{p.tag}</div>
          <ul>
            {p.features.map((f) => (
              <li>
                <Fragment set:html={checkIcon(p.featured ? '#FFFFFF' : '#1A1A1A')} />
                {f}
              </li>
            ))}
          </ul>
          {p.comingSoon
            ? <span class="btn btn-soon" aria-disabled="true">En cours de développement</span>
            : <a href={p.href} class="btn btn-primary">Commencer</a>}
        </div>
      ))}
    </div>
  </div>
</section>
