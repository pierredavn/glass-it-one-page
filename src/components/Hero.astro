---
// 1. Hero — full-bleed photo, glass pill, headline, CTAs, floating glass cards
---

<section class="hero" data-screen-label="01 Hero">
  <div class="hero-bg" aria-hidden="true"></div>
  <div class="hero-veil" aria-hidden="true"></div>

  <div class="hero-floats" aria-hidden="true">
    <div class="float-card fc-1">
      <div
        class="swatch"
        style="background-image:url('https://images.unsplash.com/photo-1555396273-367ea4eb4db5?w=200&q=80')"
      ></div>
      <div>
        <div style="font-weight:600">Burrata · 14€</div>
        <div style="color:#6B6B6B;font-size:11px">Ajouté à votre carte</div>
      </div>
    </div>

    <div class="float-card fc-2">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="3" width="7" height="7" rx="1" />
        <rect x="14" y="3" width="7" height="7" rx="1" />
        <rect x="3" y="14" width="7" height="7" rx="1" />
        <path d="M14 14h3v3h-3zM20 14h1M17 20h1M14 21h1M20 17h1M19 19h2M20 21h1" />
      </svg>
      <div>
        <div style="font-weight:600">QR scanné · 1 247×</div>
        <div style="color:#6B6B6B;font-size:11px">cette semaine</div>
      </div>
    </div>

    <div class="float-card fc-3">
      <div style="width:28px;height:28px;border-radius:8px;background:linear-gradient(135deg,#2D8A55,#7BC998);display:flex;align-items:center;justify-content:center;color:#fff">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12" />
        </svg>
      </div>
      <div>
        <div style="font-weight:600">Menu publié</div>
        <div style="color:#6B6B6B;font-size:11px">Il y a 12 secondes</div>
      </div>
    </div>
  </div>

  <div class="hero-inner">
    <span class="pill"><span class="dot"></span>Nouveau · Menu numérique</span>
    <h1>Le menu qui<br />donne faim, <i>avant</i><br />même d'arriver.</h1>
    <p class="lead">
      Glass It transforme la carte de votre restaurant en expérience numérique premium,
      accessible en 3 secondes via QR code.
    </p>
    <div class="hero-ctas">
      <a href="#cta" class="btn btn-primary">
        Essayer gratuitement
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </a>
      <a href="#demo" class="btn btn-glass">
        <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="6,4 20,12 6,20" /></svg>
        Voir une démo
      </a>
    </div>
  </div>

  <div class="scroll-cue" aria-hidden="true">
    <span>scroll</span>
    <span class="line"></span>
  </div>
</section>
