---
// 3. Problem / Solution — before / after side-by-side cards
const problems = [
  'Réimpression à chaque changement de prix',
  "Pas de photos, pas d'envie",
  'Impossible à traduire pour les touristes',
  'Vous payez chaque détail à votre imprimeur',
];

const solutions = [
  'Mise à jour en 2 clics, sans réimpression',
  'Photos HD, descriptions élégantes',
  'Traductions automatiques · 12 langues',
  'Une seule plateforme, pour toujours',
];
---

<section class="ps section-pad">
  <div class="container">
    <div class="section-head center reveal">
      <span class="eyebrow">Avant · Après</span>
      <h2 class="section-title">La carte papier a fait <i>son temps</i>.</h2>
      <p class="section-sub">
        Vos clients méritent mieux qu'un menu froissé. Et vous, mieux que de l'impression à chaque mise à jour.
      </p>
    </div>

    <div class="ps-grid">
      <div class="ps-col problem reveal">
        <span class="ps-tag">Avant</span>
        <h3>La carte papier</h3>
        <p style="color:var(--ink-2)">
          Statique, coûteuse, vite obsolète, et zéro façon de mettre en valeur vos plats.
        </p>
        <ul class="ps-list">
          {problems.map((item) => (
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="#A84646" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18" />
                <line x1="6" y1="6" x2="18" y2="18" />
              </svg>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <div class="ps-divider reveal" data-delay="1" aria-hidden="true">
        <div class="arrow">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </div>
      </div>

      <div class="ps-col solution reveal" data-delay="2">
        <span class="ps-tag">Avec Glass It</span>
        <h3>Le menu vivant</h3>
        <p style="color:var(--ink-2)">
          Un QR code, une carte qui vit, des plats qui donnent envie. Et tout reste sous votre contrôle.
        </p>
        <ul class="ps-list">
          {solutions.map((item) => (
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="#1A1A1A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12" />
              </svg>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
