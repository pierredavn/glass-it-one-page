---
// 8. Final CTA — dark section with photo background
import { REGISTER_URL } from '../urls';
---

<section class="final" id="cta">
  <div class="container reveal">
    <h2>Prêt à <i>moderniser</i> votre menu ?</h2>
    <p>Commencez gratuitement, sans carte bancaire. Votre menu en ligne en 5 minutes.</p>
    <a href={REGISTER_URL} class="btn btn-light">
      Créer mon menu gratuit
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12" />
        <polyline points="12 5 19 12 12 19" />
      </svg>
    </a>
    <div class="reassure">
      <span class="dot"></span>Aucune carte bancaire requise · Installation en 5 min
    </div>
  </div>
</section>
